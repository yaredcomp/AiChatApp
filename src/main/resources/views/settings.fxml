<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox fx:id="root" spacing="0" styleClass="settings-root" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lj.aichatapp.controllers.SettingsController" prefWidth="950" prefHeight="650">
    <padding>
        <Insets bottom="0" left="0" right="0" top="0" />
    </padding>
    
    <HBox spacing="0" VBox.vgrow="ALWAYS">
        <VBox styleClass="settings-sidebar" minWidth="180" maxWidth="180">
            <padding>
                <Insets top="24" bottom="24" left="16" right="16"/>
            </padding>
            
            <Label text="Settings" styleClass="settings-sidebar-title"/>
            
            <Region prefHeight="24"/>
            
            <VBox spacing="4">
                <Button onAction="#switchToGeneral" styleClass="settings-nav-btn" id="nav-general">
                    <graphic>
                        <FontIcon iconLiteral="fas-sliders-h" iconSize="16"/>
                    </graphic>
                    <text>General</text>
                </Button>
                <Button onAction="#switchToProviders" styleClass="settings-nav-btn" id="nav-providers">
                    <graphic>
                        <FontIcon iconLiteral="fas-server" iconSize="16"/>
                    </graphic>
                    <text>Providers</text>
                </Button>
                <Button onAction="#switchToModels" styleClass="settings-nav-btn" id="nav-models">
                    <graphic>
                        <FontIcon iconLiteral="fas-database" iconSize="16"/>
                    </graphic>
                    <text>Models</text>
                </Button>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <VBox spacing="8">
                <Label text="Version 1.0.0" styleClass="settings-version"/>
            </VBox>
        </VBox>
        
        <Separator orientation="VERTICAL" styleClass="settings-sidebar-separator"/>
        
        <VBox HBox.hgrow="ALWAYS" spacing="0">
            <ScrollPane VBox.vgrow="ALWAYS" hbarPolicy="NEVER" styleClass="settings-content-scroll">
                <VBox spacing="24">
                    <padding>
                        <Insets top="32" right="32" bottom="32" left="32"/>
                    </padding>
                    <!-- General Section -->
                    <VBox fx:id="generalSection" spacing="20">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="fas-sliders-h" iconSize="24" styleClass="section-icon"/>
                            <Label text="General" styleClass="settings-section-title"/>
                        </HBox>
                        
                        <VBox styleClass="settings-card">
                            <VBox spacing="16">
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Theme" styleClass="card-label"/>
                                        <Label text="Switch between light and dark mode" styleClass="card-description"/>
                                    </VBox>
                                    <ToggleButton fx:id="themeToggle" styleClass="modern-toggle"/>
                                </HBox>
                                
                                <Separator styleClass="card-separator"/>
                                
                                <GridPane hgap="16" vgap="16">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="NEVER" minWidth="100"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                    </columnConstraints>
                                    
                                    <Label text="Font Family" styleClass="card-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <ComboBox fx:id="fontFamilyCombo" maxWidth="Infinity" styleClass="modern-combo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                    
                                    <Label text="Font Size" styleClass="card-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                    <Spinner fx:id="fontSizeSpinner" min="8" max="24" initialValue="14" amountToStepBy="1" editable="true" prefWidth="100" styleClass="modern-spinner" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                </GridPane>
                            </VBox>
                        </VBox>
                        
                        <VBox styleClass="settings-card">
                            <VBox spacing="12">
                                <VBox spacing="4">
                                    <Label text="System Prompt" styleClass="card-label"/>
                                    <Label text="The core instruction that defines AI behavior" styleClass="card-description"/>
                                </VBox>
                                <TextArea fx:id="systemPromptArea" editable="false" wrapText="true" prefRowCount="3" styleClass="read-only-area"/>
                            </VBox>
                        </VBox>
                    </VBox>
                    
                    <!-- Providers Section -->
                    <VBox fx:id="providersSection" spacing="20" visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="fas-server" iconSize="24" styleClass="section-icon"/>
                            <Label text="Providers &amp; API Keys" styleClass="settings-section-title"/>
                        </HBox>
                        
                        <VBox styleClass="settings-card">
                            <VBox spacing="16">
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Active Provider" styleClass="card-label"/>
                                        <Label text="Select which AI provider to use" styleClass="card-description"/>
                                    </VBox>
                                    <ChoiceBox fx:id="providerChoice" prefWidth="180" styleClass="modern-choice"/>
                                </HBox>
                            </VBox>
                        </VBox>
                        
                        <VBox styleClass="settings-card">
                            <VBox spacing="16">
                                <Label text="API Keys" styleClass="card-label"/>
                                
                                <VBox spacing="16">
                                    <VBox spacing="8">
                                        <Label text="Ollama Host" styleClass="input-label"/>
                                        <TextField fx:id="ollamaHost" promptText="http://localhost:11434" styleClass="modern-text-field"/>
                                    </VBox>
                                    
                                    <VBox spacing="8">
                                        <Label text="OpenRouter API Key" styleClass="input-label"/>
                                        <HBox spacing="8">
                                            <PasswordField fx:id="openRouterKeyField" promptText="Enter API key" HBox.hgrow="ALWAYS" styleClass="modern-text-field"/>
                                            <TextField fx:id="openRouterKeyText" promptText="Enter API key" managed="false" visible="false" HBox.hgrow="ALWAYS" styleClass="modern-text-field"/>
                                            <ToggleButton fx:id="openRouterToggle" styleClass="icon-button">
                                                <graphic><FontIcon iconLiteral="fas-eye" iconSize="14"/></graphic>
                                            </ToggleButton>
                                        </HBox>
                                    </VBox>
                                    
                                    <VBox spacing="8">
                                        <Label text="Groq API Key" styleClass="input-label"/>
                                        <HBox spacing="8">
                                            <PasswordField fx:id="groqKeyField" promptText="Enter API key" HBox.hgrow="ALWAYS" styleClass="modern-text-field"/>
                                            <TextField fx:id="groqKeyText" promptText="Enter API key" managed="false" visible="false" HBox.hgrow="ALWAYS" styleClass="modern-text-field"/>
                                            <ToggleButton fx:id="groqToggle" styleClass="icon-button">
                                                <graphic><FontIcon iconLiteral="fas-eye" iconSize="14"/></graphic>
                                            </ToggleButton>
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </VBox>
                        </VBox>
                    </VBox>
                    
                    <!-- Models Section -->
                    <VBox fx:id="modelsSection" spacing="20" visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="fas-database" iconSize="24" styleClass="section-icon"/>
                            <Label text="Manage Models" styleClass="settings-section-title"/>
                        </HBox>
                        
                        <HBox spacing="20" VBox.vgrow="ALWAYS">
                            <VBox spacing="12" HBox.hgrow="ALWAYS">
                                <Label text="Add New Model" styleClass="card-label"/>
                                <TextField fx:id="newModelField" promptText="Model name (e.g., llama3)" styleClass="modern-text-field"/>
                                <Button onAction="#onAddModel" text="Add Model" maxWidth="Infinity" styleClass="action-button">
                                    <graphic><FontIcon iconLiteral="fas-plus-circle" iconSize="14"/></graphic>
                                </Button>
                                
                                <Region prefHeight="16"/>
                                
                                <Label text="Auto-Discovery" styleClass="card-label"/>
                                <Button onAction="#onFetchModels" text="Fetch Models from API" maxWidth="Infinity" styleClass="action-button">
                                    <graphic><FontIcon iconLiteral="fas-sync-alt" iconSize="14"/></graphic>
                                </Button>
                                <Label text="Automatically fetch available models from the selected provider" wrapText="true" styleClass="card-description"/>
                            </VBox>
                            
                            <Separator orientation="VERTICAL" styleClass="vertical-separator"/>
                            
                            <VBox spacing="12" HBox.hgrow="ALWAYS">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="Available Models" styleClass="card-label"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="currentModelLabel" text="None selected" styleClass="selected-model-label"/>
                                </HBox>
                                <ListView fx:id="modelsList" VBox.vgrow="ALWAYS" styleClass="modern-list-view"/>
                                <Button onAction="#onDeleteModel" text="Delete Selected" maxWidth="Infinity" styleClass="danger-button">
                                    <graphic><FontIcon iconLiteral="fas-trash-alt" iconSize="14"/></graphic>
                                </Button>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
            
            <HBox styleClass="settings-footer" alignment="CENTER_RIGHT" spacing="12">
                <Button onAction="#onCancel" text="Cancel" styleClass="cancel-button"/>
                <Button onAction="#onSave" text="Save Changes" styleClass="save-button">
                    <graphic><FontIcon iconLiteral="fas-check" iconSize="14" iconColor="white"/></graphic>
                </Button>
            </HBox>
        </VBox>
    </HBox>
</VBox>