<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane fx:id="root" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lj.aichatapp.controllers.MainController">

    <top>
        <VBox styleClass="title-bar-container">
            <HBox fx:id="titleBar" styleClass="title-bar" alignment="CENTER_LEFT">
                <HBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <FontIcon iconLiteral="fas-graduation-cap" iconSize="22" styleClass="app-icon"/>
                    <Label text="iTutor" styleClass="app-title"/>
                    <Region prefWidth="16"/>
                    <Label fx:id="currentModelIndicator" text="" styleClass="model-indicator"/>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="6">
                    <Button fx:id="btnSettings" onAction="#onOpenSettings" styleClass="window-button">
                        <graphic>
                            <FontIcon iconLiteral="fas-cog" iconSize="14"/>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox fx:id="navPanel" styleClass="nav-panel" prefWidth="280" spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10" VBox.vgrow="NEVER">
                <TextField fx:id="searchField" promptText="Search chats..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <Button fx:id="navToggle" onAction="#onToggleNav" styleClass="icon-button" style="-fx-padding: 6;">
                    <tooltip>
                        <Tooltip text="Toggle Sidebar" />
                    </tooltip>
                    <graphic>
                        <FontIcon iconLiteral="fas-chevron-left" iconSize="14"/>
                    </graphic>
                </Button>
            </HBox>

            <VBox fx:id="navContent" spacing="10" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets right="36"/>
                </padding>
                <VBox spacing="8">
                    <Button onAction="#onNewChat" maxWidth="Infinity" styleClass="new-chat-btn">
                        <graphic>
                            <FontIcon iconLiteral="fas-plus" iconSize="14"/>
                        </graphic>
                        <text>New Chat</text>
                    </Button>

                    <Button onAction="#onOpenPrompts" maxWidth="Infinity" styleClass="prompts-btn">
                        <graphic>
                            <FontIcon iconLiteral="fas-bookmark" iconSize="14"/>
                        </graphic>
                        <text>Prompt Library</text>
                    </Button>
                </VBox>

                <Region prefHeight="8"/>

                <Label text="Recent Chats" styleClass="nav-header"/>

                <ListView fx:id="chatHistoryList" VBox.vgrow="ALWAYS" styleClass="chat-history-list"/>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content">
            <StackPane VBox.vgrow="ALWAYS">
                <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="chat-scroll-pane">
                   <content>
                        <VBox fx:id="messagesBox" spacing="8" styleClass="messages-container">
                            <padding>
                                <Insets bottom="24" left="40" right="40" top="24" />
                            </padding>
                        </VBox>
                   </content>
                </ScrollPane>
                
                <VBox fx:id="emptyState" styleClass="empty-state" alignment="CENTER" visible="true">
                    <VBox spacing="16" alignment="CENTER">
                        <StackPane styleClass="empty-icon-container">
                            <FontIcon iconLiteral="fas-comments" iconSize="56" styleClass="empty-icon"/>
                        </StackPane>
                        <VBox spacing="8" alignment="CENTER">
                            <Label text="Welcome to iTutor" styleClass="empty-title"/>
                            <Label text="Start a conversation or select an existing chat" styleClass="empty-subtitle"/>
                        </VBox>
                        <HBox spacing="12" alignment="CENTER">
                            <Button onAction="#onNewChat" maxWidth="Infinity" styleClass="new-chat-btn">
                                <graphic>
                                    <FontIcon iconLiteral="fas-plus" iconSize="14"/>
                                </graphic>
                                <text>New Chat</text>
                            </Button>
                        </HBox>
                    </VBox>
                </VBox>
            </StackPane>

            <VBox styleClass="input-area">
                <VBox styleClass="input-container" spacing="6">
                    <padding>
                        <Insets bottom="8" left="24" right="24" top="12"/>
                    </padding>

                    <HBox alignment="CENTER" spacing="14">
                        <HBox spacing="10" alignment="CENTER" styleClass="input-box-wrapper" HBox.hgrow="ALWAYS">
                            <TextArea fx:id="inputField" onKeyPressed="#handleInputKeyPressed" promptText="Ask iTutor anything..." HBox.hgrow="ALWAYS" styleClass="chat-input" wrapText="true" prefRowCount="1"/>
                            <Button fx:id="btnSend" onAction="#onSendMessage" styleClass="send-button">
                                <graphic>
                                    <FontIcon iconLiteral="fas-paper-plane" iconSize="16"/>
                                </graphic>
                            </Button>
                        </HBox>
                    </HBox>

                    <StackPane>
                        <Label fx:id="typingIndicator" styleClass="typing-indicator" text="" StackPane.alignment="CENTER"/>
                        <Label fx:id="charCount" styleClass="char-count" text="" StackPane.alignment="CENTER_RIGHT"/>
                    </StackPane>
                </VBox>
                <Label text="AI can make mistakes. Please verify important information." styleClass="disclaimer-text" alignment="CENTER" maxWidth="Infinity">
                    <padding>
                        <Insets bottom="12" top="0"/>
                    </padding>
                </Label>
            </VBox>
        </VBox>
    </center>

</BorderPane>